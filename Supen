<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Local Penalty Shootout</title>
<style>
:root{--ui:#071522;--gold:#ffd45a;--blue:#48b6ff;--red:#ff5a6e;--green:#55d66b}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at top,#18385e,#07111d 70%);font-family:Inter,Segoe UI,Arial,sans-serif;color:white;display:flex;align-items:center;justify-content:center;overflow:hidden}.app{width:min(1200px,100vw);padding:10px}.hud{display:grid;grid-template-columns:1.2fr 1fr 1.2fr;gap:10px;margin-bottom:10px}.panel{background:linear-gradient(180deg,rgba(8,20,34,.92),rgba(2,8,15,.86));border:1px solid rgba(255,255,255,.18);border-radius:14px;padding:10px 14px;box-shadow:0 12px 30px rgba(0,0,0,.35),inset 0 1px rgba(255,255,255,.15)}.score{font-size:28px;font-weight:900;text-align:center;color:var(--gold);letter-spacing:1px}.small{font-size:13px;color:#b9d2e9}.history{font-size:20px;letter-spacing:5px;min-height:24px}.controls{text-align:center;line-height:1.45}.stage{position:relative;width:100%;aspect-ratio:16/9;border-radius:20px;overflow:hidden;border:3px solid rgba(255,255,255,.25);box-shadow:0 30px 70px rgba(0,0,0,.55);background:#153}.stadium{position:absolute;inset:0;background:linear-gradient(#356da5 0 23%,#101826 23% 26%,#26324a 26% 48%,#1c6731 48%);}.sky{position:absolute;inset:0 0 58% 0;background:linear-gradient(#5aa5e8,#b8dcff);overflow:hidden}.cloud{position:absolute;background:rgba(255,255,255,.45);filter:blur(10px);border-radius:50%;animation:cloud 30s linear infinite}.c1{width:180px;height:50px;top:12%;left:-10%}.c2{width:240px;height:60px;top:6%;left:55%;animation-duration:42s}@keyframes cloud{to{transform:translateX(1300px)}}.stands{position:absolute;left:-4%;right:-4%;top:22%;height:31%;background:linear-gradient(180deg,#172235,#2c3a58 42%,#111923);clip-path:polygon(4% 0,96% 0,100% 100%,0 100%);box-shadow:inset 0 28px 30px rgba(0,0,0,.35)}.tier{position:absolute;left:5%;right:5%;height:4px;background:rgba(255,255,255,.2)}.crowd{position:absolute;inset:8% 6%;background-image:radial-gradient(circle,#f45 0 2px,transparent 2.5px),radial-gradient(circle,#ffd34d 0 2px,transparent 2.5px),radial-gradient(circle,#4cf 0 2px,transparent 2.5px),radial-gradient(circle,#fff 0 1.5px,transparent 2px);background-size:31px 18px,37px 21px,29px 20px,23px 19px;animation:crowd .35s infinite alternate}@keyframes crowd{to{transform:translateY(1px)}}.light{position:absolute;top:3%;width:7%;height:26%;background:linear-gradient(90deg,#444,#ddd,#555);clip-path:polygon(42% 0,58% 0,70% 100%,30% 100%)}.light:after{content:"";position:absolute;left:-60%;right:-60%;top:8%;height:45px;background:radial-gradient(ellipse,#fff 0 12%,#ffe99c 32%,transparent 72%);filter:blur(2px);opacity:.9}.l1{left:6%;transform:rotate(-10deg)}.l2{right:6%;transform:rotate(10deg)}.pitch{position:absolute;left:-7%;right:-7%;bottom:-8%;height:62%;background:repeating-linear-gradient(90deg,#2c963f 0 9%,#248b38 9% 18%);clip-path:polygon(14% 0,86% 0,100% 100%,0 100%)}.pitch:after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 50% 8%,rgba(255,255,255,.16),transparent 20%),linear-gradient(180deg,transparent,rgba(0,0,0,.28))}.mark{position:absolute;border:3px solid rgba(255,255,255,.88);transform:translateX(-50%)}.penaltyArea{left:50%;top:5%;width:48%;height:44%;border-top:0}.goalBox{left:50%;top:5%;width:25%;height:22%;border-top:0}.spot{position:absolute;left:50%;top:50%;width:9px;height:9px;border-radius:50%;background:white;transform:translate(-50%,-50%);box-shadow:0 0 10px white}.arc{position:absolute;left:50%;top:33%;width:18%;height:18%;border:3px solid rgba(255,255,255,.75);border-top:0;border-left-color:transparent;border-right-color:transparent;border-radius:0 0 50% 50%;transform:translateX(-50%)}.goal{position:absolute;left:50%;top:28%;width:46%;height:31%;transform:translateX(-50%);perspective:500px}.net{position:absolute;inset:8% 4% 0;background-image:linear-gradient(rgba(255,255,255,.35) 2px,transparent 2px),linear-gradient(90deg,rgba(255,255,255,.35) 2px,transparent 2px);background-size:26px 22px;transform:rotateX(10deg);box-shadow:inset 0 0 50px rgba(255,255,255,.2)}.post{position:absolute;background:#fff;border-radius:7px;box-shadow:0 0 10px rgba(255,255,255,.8)}.leftPost,.rightPost{top:0;bottom:0;width:13px}.leftPost{left:0}.rightPost{right:0}.crossbar{left:0;right:0;top:0;height:13px}.keeper{position:absolute;left:50%;top:44%;width:70px;height:130px;transform:translate(-50%,-50%);filter:drop-shadow(0 12px 8px rgba(0,0,0,.4));transition:filter .2s}.keeper .head{position:absolute;left:22px;top:0;width:27px;height:31px;border-radius:50%;background:#b87548}.keeper .body{position:absolute;left:17px;top:31px;width:36px;height:48px;border-radius:12px;background:linear-gradient(90deg,#ffda3e,#ff8c20)}.limb{position:absolute;background:#24385f;border-radius:12px;transform-origin:top}.armL,.armR{top:36px;width:13px;height:58px;background:#ffd13e}.armL{left:10px;transform:rotate(18deg)}.armR{right:10px;transform:rotate(-18deg)}.legL,.legR{top:76px;width:15px;height:58px}.legL{left:20px}.legR{right:20px}.glove{position:absolute;width:20px;height:17px;border-radius:50%;background:white;top:86px}.gL{left:3px}.gR{right:3px}.ball{position:absolute;left:50%;top:76%;width:30px;height:30px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#fff 0 22%,#ddd 45%,#888 100%);transform:translate(-50%,-50%);box-shadow:0 9px 12px rgba(0,0,0,.38);z-index:8}.ball:before{content:"";position:absolute;inset:7px;background:#111;clip-path:polygon(50% 0,100% 38%,80% 100%,20% 100%,0 38%)}.aimH,.aimV,.crosshair{position:absolute;z-index:20;pointer-events:none}.aimH{height:4px;width:46%;left:27%;top:43%;background:linear-gradient(90deg,transparent,var(--gold),transparent);box-shadow:0 0 12px var(--gold)}.aimV{width:4px;height:31%;left:50%;top:28%;background:linear-gradient(transparent,var(--blue),transparent);box-shadow:0 0 12px var(--blue)}.crosshair{width:34px;height:34px;border:2px solid #ffed77;border-radius:50%;transform:translate(-50%,-50%);box-shadow:0 0 14px #ffed77}.crosshair:before,.crosshair:after{content:"";position:absolute;background:#ffed77}.crosshair:before{left:15px;top:-9px;width:2px;height:48px}.crosshair:after{top:15px;left:-9px;height:2px;width:48px}.hidden{display:none!important}.message{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:clamp(42px,9vw,110px);font-weight:1000;text-shadow:0 6px 0 #000,0 0 35px currentColor;z-index:30;pointer-events:none;opacity:0;transform:scale(.7);transition:.35s}.message.show{opacity:1;transform:scale(1)}.timer{position:absolute;right:18px;top:18px;background:rgba(0,0,0,.58);border:1px solid #fff5;border-radius:12px;padding:10px 14px;font-weight:900;font-size:24px;z-index:22}.shake{animation:shake .38s}@keyframes shake{20%{transform:translateX(-10px)}40%{transform:translateX(9px)}60%{transform:translateX(-6px)}80%{transform:translateX(5px)}}button{border:0;border-radius:999px;padding:10px 16px;background:linear-gradient(#ffe27b,#e8a719);font-weight:900;color:#241600;cursor:pointer;box-shadow:0 6px 0 #8a5d00}.overlay{position:absolute;inset:0;background:rgba(4,10,18,.78);z-index:40;display:none;align-items:center;justify-content:center;text-align:center;padding:20px}.overlay.show{display:flex}.card{max-width:520px}.celebrate{position:absolute;inset:0;pointer-events:none;z-index:29;background:radial-gradient(circle,rgba(255,235,90,.5),transparent 45%);animation:pop .8s forwards}@keyframes pop{to{opacity:0;transform:scale(1.5)}}@media(max-width:760px){.hud{grid-template-columns:1fr}.panel{padding:8px}.keeper{width:52px;height:96px}.score{font-size:22px}}
</style>
</head>
<body>
<div class="app">
  <div class="hud">
    <div class="panel"><div class="small">Score</div><div class="score" id="score">Player 1 0 - 0 Player 2</div><div class="history" id="history"></div></div>
    <div class="panel controls"><b id="turn">Shooter: Player 1 | Keeper: Player 2</b><br><span id="round" class="small">Round 1 of 5</span><br><span id="instructions">Press Space to start aiming.</span></div>
    <div class="panel"><button id="restart">Restart</button><div class="small" style="margin-top:8px">Space aim/lock. Keeper: W A D + ← → after target hides.</div></div>
  </div>
  <div class="stage" id="stage">
    <div class="stadium"><div class="sky"><div class="cloud c1"></div><div class="cloud c2"></div></div><div class="light l1"></div><div class="light l2"></div><div class="stands"><div class="crowd"></div><div class="tier" style="top:25%"></div><div class="tier" style="top:50%"></div><div class="tier" style="top:75%"></div></div><div class="pitch"><div class="mark penaltyArea"></div><div class="mark goalBox"></div><div class="arc"></div><div class="spot"></div></div></div>
    <div class="goal" id="goal"><div class="net"></div><div class="post leftPost"></div><div class="post rightPost"></div><div class="post crossbar"></div></div>
    <div class="keeper" id="keeper"><div class="head"></div><div class="body"></div><div class="limb armL"></div><div class="limb armR"></div><div class="limb legL"></div><div class="limb legR"></div><div class="glove gL"></div><div class="glove gR"></div></div>
    <div class="ball" id="ball"></div><div class="aimH hidden" id="aimH"></div><div class="aimV hidden" id="aimV"></div><div class="crosshair hidden" id="crosshair"></div><div class="timer hidden" id="timer"></div><div class="message" id="message"></div><div class="overlay" id="overlay"><div class="card"><h1 id="finalTitle"></h1><p id="finalText"></p><button id="again">Play Again</button></div></div>
  </div>
</div>
<script>
'use strict';
const $=id=>document.getElementById(id), stage=$('stage'), goal=$('goal'), keeperEl=$('keeper'), ballEl=$('ball');
const ui={score:$('score'),history:$('history'),turn:$('turn'),round:$('round'),instructions:$('instructions'),timer:$('timer'),msg:$('message'),aimH:$('aimH'),aimV:$('aimV'),cross:$('crosshair'),overlay:$('overlay'),finalTitle:$('finalTitle'),finalText:$('finalText')};
const audio=(()=>{let ctx;function tone(f,d,type='sine',gain=.08){ctx=ctx||new (window.AudioContext||window.webkitAudioContext)();const o=ctx.createOscillator(),g=ctx.createGain();o.type=type;o.frequency.value=f;g.gain.value=gain;o.connect(g);g.connect(ctx.destination);o.start();g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+d);o.stop(ctx.currentTime+d)}return{kick(){tone(90,.12,'square',.12);tone(170,.08,'sawtooth',.04)},goal(){[330,440,660,880].forEach((f,i)=>setTimeout(()=>tone(f,.18,'triangle',.07),i*90));this.crowd(true)},save(){tone(120,.22,'sawtooth',.12);tone(60,.35,'square',.06);this.crowd(false)},miss(){tone(150,.3,'sine',.06);setTimeout(()=>tone(110,.4,'sine',.05),180)},crowd(happy){for(let i=0;i<18;i++)setTimeout(()=>tone((happy?300:120)+Math.random()*220,.08,'sawtooth',.025),i*35)}}})();
let S, keys={};
function reset(){S={scores:[0,0],hist:[[],[]],turns:0,phase:'ready',aimX:.5,aimY:.5,t:0,target:null,shot:null,keeper:{x:.5,y:0,vx:0,vy:0,dive:0},finished:false}; ui.overlay.classList.remove('show'); ui.msg.className='message'; ui.msg.textContent=''; updateUI(); resetPositions();}
function resetPositions(){place(ballEl,.5,.76,30); setKeeper(.5,0,0); hideAim();}
function currentShooter(){return S.turns%2} function currentKeeper(){return 1-currentShooter()} function roundNo(){return Math.floor(S.turns/2)+1}
function updateUI(){ui.score.textContent=`Player 1 ${S.scores[0]} - ${S.scores[1]} Player 2`; ui.history.innerHTML=`P1 ${S.hist[0].join(' ')}<br>P2 ${S.hist[1].join(' ')}`; ui.turn.textContent=`Shooter: Player ${currentShooter()+1} | Keeper: Player ${currentKeeper()+1}`; ui.round.textContent=(S.turns<10?`Round ${roundNo()} of 5`:`Sudden Death ${Math.ceil((S.turns-9)/2)}`);}
function rectPerc(x,y){const r=stage.getBoundingClientRect();return{x:x*r.width,y:y*r.height,w:r.width,h:r.height}}
function place(el,x,y,size){el.style.left=(x*100)+'%';el.style.top=(y*100)+'%'; if(size){el.style.width=el.style.height=size+'px'}}
function setKeeper(x,y,dive){S.keeper.x=Math.max(.285,Math.min(.715,x));S.keeper.y=y;S.keeper.dive=dive;keeperEl.style.left=S.keeper.x*100+'%';keeperEl.style.top=(44-y*12)+'%';keeperEl.style.transform=`translate(-50%,-50%) rotate(${dive*55}deg) scaleX(${dive<0?-1:1})`; const walk=Math.sin(performance.now()/90)*8*(Math.abs(S.keeper.vx)>0.001); keeperEl.querySelector('.legL').style.transform=`rotate(${walk}deg)`; keeperEl.querySelector('.legR').style.transform=`rotate(${-walk}deg)`; keeperEl.querySelector('.armL').style.transform=`rotate(${18+walk}deg)`; keeperEl.querySelector('.armR').style.transform=`rotate(${-18-walk}deg)`;}
function showAim(){ui.aimH.classList.remove('hidden');ui.cross.classList.remove('hidden')} function hideAim(){ui.aimH.classList.add('hidden');ui.aimV.classList.add('hidden');ui.cross.classList.add('hidden')}
function space(){if(S.finished)return; if(S.phase==='ready'){S.phase='aimH';showAim();ui.instructions.textContent='Press Space to lock horizontal aim.'}else if(S.phase==='aimH'){S.phase='aimV';ui.aimV.classList.remove('hidden');ui.instructions.textContent='Press Space to lock vertical aim.'}else if(S.phase==='aimV'){S.target={x:S.aimX,y:S.aimY};S.phase='conceal';ui.instructions.textContent='Target locked. It hides in 1 second.';setTimeout(()=>{hideAim();S.phase='react';S.reactEnd=performance.now()+2000;ui.timer.classList.remove('hidden');ui.instructions.textContent='Keeper react! W/A/D/←/→';},1000)}}
document.addEventListener('keydown',e=>{if(e.code==='Space'){e.preventDefault();space()} keys[e.code]=true});document.addEventListener('keyup',e=>keys[e.code]=false);
function startShot(){S.phase='shot';ui.timer.classList.add('hidden');audio.kick();const start={x:.5,y:.76}, end={x:.27+S.target.x*.46,y:.28+S.target.y*.31}; const miss=end.x<.30||end.x>.70||end.y<.285||end.y>.57; if(Math.random()<.08){end.x+= (Math.random()<.5?-.08:.08); end.y+=Math.random()*.06-.03} S.shot={start,end,miss,t0:performance.now(),hit:false};}
function finish(result){S.phase='result';ui.msg.textContent=result;ui.msg.style.color=result==='GOAL'?'#56ff7b':result==='SAVED'?'#54c7ff':'#ff6070';ui.msg.classList.add('show'); if(result==='GOAL'){S.scores[currentShooter()]++;S.hist[currentShooter()].push('✓');audio.goal();let c=document.createElement('div');c.className='celebrate';stage.append(c);setTimeout(()=>c.remove(),800)}else{S.hist[currentShooter()].push('✗'); result==='SAVED'?audio.save():audio.miss()} updateUI(); setTimeout(nextTurn,1900)}
function nextTurn(){S.turns++; if(done()){S.finished=true;const w=S.scores[0]===S.scores[1]?'Draw':`Player ${S.scores[0]>S.scores[1]?1:2} wins!`;ui.finalTitle.textContent=w;ui.finalText.textContent=`Final score: ${S.scores[0]} - ${S.scores[1]}`;ui.overlay.classList.add('show');return} S.phase='ready';ui.msg.className='message';ui.instructions.textContent='Press Space to start aiming.';updateUI();resetPositions()}
function done(){if(S.turns<10)return false; if(S.scores[0]!==S.scores[1] && S.turns>=10 && S.turns%2===0)return true;return false}
function animate(now){requestAnimationFrame(animate); if(S.phase==='aimH'||S.phase==='aimV'){S.aimX=.5+.5*Math.sin(now/650);S.aimY=.5+.5*Math.sin(now/520);ui.aimV.style.left=(27+S.aimX*46)+'%';ui.aimH.style.top=(28+S.aimY*31)+'%';ui.cross.style.left=(27+S.aimX*46)+'%';ui.cross.style.top=(28+S.aimY*31)+'%'} if(S.phase==='react'){let left=mathMax(0,S.reactEnd-now);ui.timer.textContent=(left/1000).toFixed(1);controlKeeper(); if(left<=0)startShot()} if(S.phase==='shot')moveShot(now); if(S.phase==='react'||S.phase==='shot')controlKeeper();}
function mathMax(a,b){return Math.max(a,b)}
function controlKeeper(){const k=S.keeper; if(keys.KeyA)k.vx-=.0025;if(keys.KeyD)k.vx+=.0025;if(keys.ArrowLeft){k.dive=-1;k.vx=-.014} if(keys.ArrowRight){k.dive=1;k.vx=.014} if(keys.KeyW&&k.y<=0){k.vy=.028} k.vx*=.88;k.x+=k.vx;k.vy-=.0016;k.y=Math.max(0,k.y+k.vy);if(k.y===0)k.vy=0;if(!keys.ArrowLeft&&!keys.ArrowRight)k.dive*=.88;setKeeper(k.x,k.y,k.dive)}
function moveShot(now){const s=S.shot,p=Math.min(1,(now-s.t0)/1050),arc=-.18*Math.sin(Math.PI*p),x=s.start.x+(s.end.x-s.start.x)*p,y=s.start.y+(s.end.y-s.start.y)*p+arc;place(ballEl,x,y,30-12*p); const dx=x-S.keeper.x,dy=y-(.44-S.keeper.y*.12),reach=.055+(Math.abs(S.keeper.dive)*.055)+(S.keeper.y*.035); if(!s.hit&&p>.45&&Math.hypot(dx,dy)<reach){s.hit=true;stage.classList.add('shake');setTimeout(()=>stage.classList.remove('shake'),400);finish('SAVED')} if(p>=1&&!s.hit){const inGoal=s.end.x>.285&&s.end.x<.715&&s.end.y>.28&&s.end.y<.59;finish(inGoal?'GOAL':'MISS')}}
$('restart').onclick=reset;$('again').onclick=reset;reset();requestAnimationFrame(animate);
</script>
</body>
</html>